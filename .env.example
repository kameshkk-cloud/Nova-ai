# ─── NOVA AI Configuration ───────────────────────────────────
# Copy this file to .env and fill in your values.
# All settings have sensible defaults — only set what you need.

# ── LLM Provider (groq | openai | ollama) ────────────────────
NOVA_LLM_PROVIDER=groq

# ── API Keys ─────────────────────────────────────────────────
# Groq (free): https://console.groq.com
GROQ_API_KEY=

# OpenAI (paid): https://platform.openai.com
OPENAI_API_KEY=

# ── Ollama (offline, free) ───────────────────────────────────
# Install: https://ollama.ai  →  ollama pull llama3
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3

# ── Personalisation ──────────────────────────────────────────
NOVA_USER_NAME=KK Sir
NOVA_WAKE_WORD=hey nova
NOVA_VOICE_GENDER=male
